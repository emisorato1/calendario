# ═══════════════════════════════════════════
# TELEGRAM
# ═══════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_bot_token_here

# IDs de Admins (acceso total: crear, editar, cancelar, listar). Máximo 2, formato JSON.
ADMIN_TELEGRAM_IDS=[123456789,987654321]

# IDs de Editors (solo editar y listar). Puede estar vacío [] o tener varios IDs. Formato JSON.
EDITOR_TELEGRAM_IDS=[111222333,444555666]

# ═══════════════════════════════════════════
# HORARIO LABORAL
# ═══════════════════════════════════════════
# Lunes a Viernes (días 0-4 en Python, donde 0=Lunes)
WORK_DAYS_WEEKDAY_START=15:00
WORK_DAYS_WEEKDAY_END=21:00
# Sábados (día 5)
WORK_DAYS_SATURDAY_START=08:00
WORK_DAYS_SATURDAY_END=20:00
# Domingos: sin actividad (no configurar → el sistema los bloquea automáticamente)

# ═══════════════════════════════════════════
# GROQ API
# ═══════════════════════════════════════════
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.1

# ═══════════════════════════════════════════
# GOOGLE CALENDAR
# ═══════════════════════════════════════════
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json

# ═══════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════
SQLITE_DB_PATH=data/crm.db
FUZZY_MATCH_THRESHOLD=75

# ═══════════════════════════════════════════
# SISTEMA
# ═══════════════════════════════════════════
TIMEZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=DEBUG
LOG_FILE=logs/agente.log
